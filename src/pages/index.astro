---
import { getLocaleContent } from "../content";
import BaseLayout from "../layouts/BaseLayout.astro";

const content = getLocaleContent();
const { home } = content;
---

<BaseLayout>
	<section class="section home-hero">
		<div class="container home-copy">
			<h1>{home.title}</h1>
			<p class="home-subtitle">{home.subtitle}</p>
			<p class="home-slogan">{home.slogan}</p>
			<p class="home-intro">{home.intro}</p>

			<div class="action-row" aria-label="首页快捷入口">
				{home.actions.map((action) => (
					<a
						class={action.variant === "primary" ? "button primary" : "button secondary"}
						href={action.href}
						target={action.external ? "_blank" : undefined}
						rel={action.external ? "noreferrer" : undefined}
					>
						{action.label}
					</a>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
