---
import { getLocaleContent } from "../content";
import BaseLayout from "../layouts/BaseLayout.astro";

const content = getLocaleContent();
const { about } = content;
---

<BaseLayout>
	<section class="section">
		<div class="container">
			<h1 class="page-title">{about.title}</h1>

			<section class="content-block" aria-labelledby="about-summary">
				<h2 id="about-summary">{about.summaryTitle}</h2>
				<p class="page-desc">{about.description}</p>
			</section>

			<section class="content-block" aria-labelledby="about-keywords">
				<h2 id="about-keywords">{about.keywordsTitle}</h2>
				<ul class="info-list">
					{about.keywords.map((keyword) => <li>{keyword}</li>)}
				</ul>
			</section>

			<section class="content-block" aria-labelledby="about-focuses">
				<h2 id="about-focuses">{about.focusTitle}</h2>
				<ul class="info-list">
					{about.focuses.map((focus) => <li>{focus}</li>)}
				</ul>
			</section>
		</div>
	</section>
</BaseLayout>
