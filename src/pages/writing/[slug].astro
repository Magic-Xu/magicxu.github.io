---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { formatPubDate, getPublishedPosts } from "../../lib/blog";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const posts = await getPublishedPosts();

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post }
	}));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
	<section class="section">
		<div class="container article-shell">
			<a class="text-link back-link" href="/writing/">返回 Writing</a>

			<article class="article-detail">
				<header class="article-header">
					<h1 class="page-title">{post.data.title}</h1>
					<p class="meta-line">发布日期：{formatPubDate(post.data.pubDate)}</p>
					{post.data.tags && post.data.tags.length > 0 && (
						<ul class="tag-list" aria-label="文章标签">
							{post.data.tags.map((tag) => <li>{tag}</li>)}
						</ul>
					)}
					<p class="page-desc article-summary">{post.data.description}</p>
				</header>

				<div class="article-prose">
					<Content />
				</div>
			</article>
		</div>
	</section>
</BaseLayout>
