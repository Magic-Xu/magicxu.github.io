---
interface Props {
	title: string;
	summary: string;
	date: string;
	category: string;
	href: string;
}

const { title, summary, date, category, href } = Astro.props;
---

<article class="article-card">
	<p class="meta-line">{category} · {date}</p>
	<h3>{title}</h3>
	<p>{summary}</p>
	<a class="text-link" href={href}>阅读全文（占位）</a>
</article>
