---
interface Props {
	name: string;
	description: string;
	status: string;
	stack: string[];
	linkLabel: string;
	linkHref: string;
}

const { name, description, status, stack, linkLabel, linkHref } = Astro.props;
const isExternal = linkHref.startsWith("http");
---

<article class="project-card">
	<header class="project-card-head">
		<h3>{name}</h3>
		<span class="status-chip">{status}</span>
	</header>
	<p>{description}</p>
	<ul class="stack-list" aria-label="技术栈">
		{stack.map((item) => <li>{item}</li>)}
	</ul>
	<a class="text-link" href={linkHref} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noreferrer" : undefined}>
		{linkLabel}
	</a>
</article>
