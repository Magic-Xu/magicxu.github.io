---
import { getLocaleContent } from "../content";
import { siteConfig } from "../data/site";

const year = new Date().getFullYear();
const content = getLocaleContent();
---

<footer class="site-footer">
	<div class="container footer-inner">
		<div>
			<p class="footer-copy">© {year} {siteConfig.title}. {content.footer.note}</p>
			<p class="footer-note">{siteConfig.description}</p>
		</div>
		<div class="footer-links">
			<a href={siteConfig.github} target="_blank" rel="noreferrer">{content.footer.githubLabel}</a>
			<a href={`mailto:${siteConfig.email}`}>{content.footer.emailLabel}</a>
		</div>
	</div>
</footer>
